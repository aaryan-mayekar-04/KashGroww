# KashGroww Email Configuration
# Copy this file to .env and fill in your credentials

# ── BREVO CONFIGURATION (Recommended) ──────────────────────────
# 1. Create account: https://app.brevo.com
# 2. Go to Settings → SMTP & API
# 3. Copy your SMTP password
BREVO_API_KEY=your_brevo_smtp_password_here
BREVO_EMAIL=your.email@brevo-email.com

# ── GMAIL CONFIGURATION ────────────────────────────────────────
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password (remove spaces)
GMAIL_PASSWORD=your16characterapppassword
GMAIL_EMAIL=your.email@gmail.com
